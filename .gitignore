# Temporary files
# (Commented out to allow tracking of research data and results)
# results/data/*.json
# results/data/*.csv
results/figures/*.pdf
results/figures/*.png
# results/tables/*.tex
# results/logs/*.txt
# results/logs/*.log
!results/data/.gitkeep
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/logs/.gitkeep

# Explicitly track the hardware comparison figure as requested
!results/figures/fig_hardware_comparison.pdf
!results/figures/fig_hardware_comparison.png

# Do not track article source and bibliography
text.tex
*.bib
references.bib
!results/logs/.gitkeep
